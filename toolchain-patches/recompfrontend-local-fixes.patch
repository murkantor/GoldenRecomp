+    case SDL_EventType::SDL_MOUSEBUTTONDOWN:
+        // @goldenrecomp local fix (upstream gap): allow binding mouse
+        // buttons — they scan under the Keyboard device slot, the usual
+        // PC-port convention. input_id = SDL button index.
+        if (binding::is_binding()) {
